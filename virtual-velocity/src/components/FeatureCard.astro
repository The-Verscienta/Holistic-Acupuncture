---
import Card from './Card.astro';

interface Props {
  title: string;
  description: string;
  icon: string;
  /**
   * centered: icon above title (default) — used for "how it works", certifications, parking cards
   * horizontal: icon left of text — used for mission, insurance cards
   */
  layout?: 'centered' | 'horizontal';
  cardVariant?: 'default' | 'elevated' | 'bordered';
}

const { title, description, icon, layout = 'centered', cardVariant = 'elevated' } = Astro.props;
---

{layout === 'centered' ? (
  <Card variant={cardVariant} padding="md" class="text-center">
    <div class="w-16 h-16 mx-auto mb-4 bg-sage-100 rounded-full flex items-center justify-center">
      <svg class="w-8 h-8 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon}></path>
      </svg>
    </div>
    <h3 class="font-semibold text-charcoal mb-2">{title}</h3>
    <p class="text-sm text-gray-600">{description}</p>
  </Card>
) : (
  <Card variant={cardVariant} padding="lg">
    <div class="flex items-start gap-4">
      <div class="w-12 h-12 rounded-full bg-sage-100 flex items-center justify-center flex-shrink-0">
        <svg class="w-6 h-6 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon}></path>
        </svg>
      </div>
      <div>
        <h3 class="text-lg font-semibold text-charcoal mb-2">{title}</h3>
        <p class="text-gray-600 text-sm">{description}</p>
      </div>
    </div>
  </Card>
)}
