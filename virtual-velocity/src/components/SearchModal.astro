---
// Search Modal Component using Pagefind
// Opens with Cmd/Ctrl+K or clicking the search button
// Pagefind indexes are generated at build time
---

<!-- Search Trigger Button -->
<button
  id="search-trigger"
  type="button"
  class="flex items-center gap-2 px-3 py-2 text-gray-600 hover:text-sage-700 font-medium transition-colors"
  aria-label="Search"
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
  </svg>
  <span class="hidden md:inline text-sm">Search</span>
  <kbd class="hidden md:inline-flex items-center gap-1 px-2 py-0.5 text-xs font-mono bg-gray-100 text-gray-500 rounded border border-gray-200">
    <span class="text-xs">⌘</span>K
  </kbd>
</button>

<!-- Search Modal -->
<div
  id="search-modal"
  class="fixed inset-0 z-50 hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Search"
>
  <!-- Backdrop -->
  <div class="fixed inset-0 bg-black/50 backdrop-blur-sm" id="search-backdrop"></div>

  <!-- Modal Content -->
  <div class="fixed inset-x-4 top-20 md:inset-x-auto md:left-1/2 md:-translate-x-1/2 md:w-full md:max-w-2xl">
    <div class="relative bg-white rounded-xl shadow-2xl overflow-hidden">

      <!-- X close button — absolutely positioned top-right, above pagefind's clear button -->
      <button
        id="search-close"
        type="button"
        class="absolute top-2.5 right-2.5 z-10 p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-md transition-colors"
        aria-label="Close search"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <!-- Pagefind Search Container -->
      <div id="pagefind-container" class="pagefind-ui-container"></div>

      <!-- Footer -->
      <div class="px-5 py-3 bg-gray-50 border-t border-gray-200 flex items-center justify-between text-xs text-gray-400">
        <span>Press <kbd class="px-1.5 py-0.5 font-mono bg-white rounded border border-gray-200">ESC</kbd> to close</span>
        <a href="/blog" class="text-sage-600 hover:text-sage-700 font-medium">
          View all articles
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Pagefind Styles -->
<style is:global>
  /* Pagefind UI Customization */
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #657a52;
    --pagefind-ui-text: #2d3436;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e5e7eb;
    --pagefind-ui-tag: #f3f4f6;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: Inter, system-ui, -apple-system, sans-serif;
  }

  .pagefind-ui-container {
    padding: 0;
  }

  .pagefind-ui .pagefind-ui__search-input {
    font-size: 1.125rem;
    /* right padding makes room for the clear button; no background-image — pagefind renders its own icon */
    padding: 1rem 3.5rem 1rem 1.25rem;
    border: none;
    border-bottom: 1px solid var(--pagefind-ui-border);
    border-radius: 0;
  }

  .pagefind-ui .pagefind-ui__search-input:focus {
    outline: none;
    box-shadow: none;
    border-color: var(--pagefind-ui-primary);
  }

  /* Push clear button left enough to not sit behind the X close button */
  .pagefind-ui .pagefind-ui__search-clear {
    top: 50%;
    transform: translateY(-50%);
    right: 2.5rem;
    padding: 0.25rem 0.5rem;
    background: #f3f4f6;
    border-radius: 4px;
    color: #6b7280;
  }

  .pagefind-ui .pagefind-ui__results-area {
    margin-top: 0;
    padding: 0;
  }

  .pagefind-ui .pagefind-ui__results {
    padding: 0;
    max-height: 24rem;
    overflow-y: auto;
  }

  .pagefind-ui .pagefind-ui__result {
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid #f3f4f6;
    margin: 0;
  }

  .pagefind-ui .pagefind-ui__result:hover {
    background: #f6f7f3;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: var(--pagefind-ui-text);
    font-weight: 500;
    text-decoration: none;
  }

  .pagefind-ui .pagefind-ui__result-link:hover {
    color: var(--pagefind-ui-primary);
  }

  .pagefind-ui .pagefind-ui__result-title {
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .pagefind-ui .pagefind-ui__result-excerpt {
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.5;
  }

  .pagefind-ui .pagefind-ui__result-excerpt mark {
    background: #fef3c7;
    color: inherit;
    padding: 0.125rem 0.25rem;
    border-radius: 2px;
  }

  .pagefind-ui .pagefind-ui__message {
    padding: 2rem;
    text-align: center;
    color: #6b7280;
  }

  .pagefind-ui .pagefind-ui__button {
    background: var(--pagefind-ui-primary);
    color: white;
    border: none;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-weight: 500;
    cursor: pointer;
    margin-top: 1rem;
  }

  .pagefind-ui .pagefind-ui__button:hover {
    background: #4f5f40;
  }

  /* Hide image thumbnails for cleaner look */
  .pagefind-ui .pagefind-ui__result-image {
    display: none;
  }

  /* Loading state */
  .pagefind-ui .pagefind-ui__loading {
    padding: 2rem;
    text-align: center;
  }
</style>

<script>
  // Import Pagefind UI dynamically (only available after build)
  let pagefindLoaded = false;

  const searchTrigger = document.getElementById('search-trigger');
  const searchModal = document.getElementById('search-modal');
  const searchBackdrop = document.getElementById('search-backdrop');
  const searchClose = document.getElementById('search-close');
  const pagefindContainer = document.getElementById('pagefind-container');

  async function loadPagefind() {
    if (pagefindLoaded) return;

    try {
      // Load Pagefind UI CSS
      const cssLink = document.createElement('link');
      cssLink.rel = 'stylesheet';
      cssLink.href = '/pagefind/pagefind-ui.css';
      document.head.appendChild(cssLink);

      // Load Pagefind UI JS as a script tag — pagefind-ui.js is an IIFE that
      // sets window.PagefindUI, not an ES module with named exports.
      await new Promise<void>((resolve, reject) => {
        const script = document.createElement('script');
        script.src = '/pagefind/pagefind-ui.js';
        script.onload = () => resolve();
        script.onerror = () => reject(new Error('Failed to load /pagefind/pagefind-ui.js'));
        document.head.appendChild(script);
      });

      // @ts-ignore - set by the IIFE above
      const PagefindUI = window.PagefindUI;
      if (!PagefindUI) throw new Error('PagefindUI not found on window after script load');

      // Initialize Pagefind UI
      new PagefindUI({
        element: '#pagefind-container',
        showSubResults: true,
        showImages: false,
        excerptLength: 15,
        resetStyles: false,
        autofocus: true,
        translations: {
          placeholder: 'Search articles, conditions, services...',
          zero_results: 'No results found for "[SEARCH_TERM]"',
          many_results: '[COUNT] results',
          one_result: '1 result',
          searching: 'Searching...',
        }
      });

      pagefindLoaded = true;
    } catch (error) {
      if (pagefindContainer) {
        const isDev = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
        const msg = isDev
          ? 'Run <code class="bg-gray-100 px-2 py-1 rounded">npm run build</code> to generate the search index.'
          : `Search failed to load. <span class="block text-xs mt-1 text-gray-400">${error instanceof Error ? error.message : String(error)}</span>`;
        pagefindContainer.innerHTML = `
          <div class="px-4 py-8 text-center text-gray-500">
            <svg class="w-12 h-12 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <p class="text-lg font-medium text-gray-700 mb-2">${isDev ? 'Search Available After Build' : 'Search Unavailable'}</p>
            <p class="text-sm">${msg}</p>
          </div>
        `;
      }
    }
  }

  function openSearch() {
    loadPagefind();
    searchModal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    // Focus the search input after Pagefind loads
    setTimeout(() => {
      const input = document.querySelector('.pagefind-ui__search-input') as HTMLInputElement;
      input?.focus();
    }, 100);
  }

  function closeSearch() {
    searchModal?.classList.add('hidden');
    document.body.style.overflow = '';

    // Clear the search input
    const input = document.querySelector('.pagefind-ui__search-input') as HTMLInputElement;
    if (input) input.value = '';

    // Clear results
    const results = document.querySelector('.pagefind-ui__results-area');
    if (results) results.innerHTML = '';
  }

  // Event Listeners
  searchTrigger?.addEventListener('click', openSearch);
  searchBackdrop?.addEventListener('click', closeSearch);
  searchClose?.addEventListener('click', closeSearch);

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    // Open with Cmd/Ctrl+K
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (searchModal?.classList.contains('hidden')) {
        openSearch();
      } else {
        closeSearch();
      }
    }

    // Close with Escape
    if (e.key === 'Escape' && !searchModal?.classList.contains('hidden')) {
      closeSearch();
    }
  });
</script>
