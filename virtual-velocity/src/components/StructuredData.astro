---
import { CONTACT, HOURS, SITE_URL, SOCIAL, REVIEW_STATS, GOOGLE_BUSINESS_URL, SERVICE_AREAS } from '../lib/config';

// Structured Data for LocalBusiness (Acupuncture Clinic)
const structuredData = {
  "@context": "https://schema.org",
  "@type": ["MedicalBusiness", "LocalBusiness"],
  "@id": `${SITE_URL}/#organization`,
  name: "Acupuncture & Holistic Health Associates",
  alternateName: "Milwaukee Acupuncture",
  description: "Expert acupuncture and traditional Chinese medicine in Milwaukee. Over 25 years of experience treating chronic pain, stress, fertility issues, and more.",
  url: SITE_URL,
  hasMap: `https://www.google.com/maps/dir/?api=1&destination_place_id=${CONTACT.address.googlePlaceId}`,
  logo: {
    "@type": "ImageObject",
    url: `${SITE_URL}/logo.png`,
    width: 703,
    height: 827
  },
  image: {
    "@type": "ImageObject",
    url: `${SITE_URL}/logo.png`,
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: String(REVIEW_STATS.rating),
    reviewCount: String(REVIEW_STATS.count),
    bestRating: "5",
    worstRating: "1"
  },
  telephone: `+1${CONTACT.phone.replace(/\D/g, '')}`,
  email: CONTACT.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: CONTACT.address.street,
    addressLocality: CONTACT.address.city,
    addressRegion: CONTACT.address.state,
    postalCode: CONTACT.address.zip,
    addressCountry: "US"
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 43.145805,
    longitude: -87.888920
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday"],
      opens: "09:00",
      closes: "19:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Friday", "Saturday", "Sunday"],
      opens: "00:00",
      closes: "00:00"
    }
  ],
  priceRange: "$$",
  paymentAccepted: ["Cash", "Credit Card"],
  currenciesAccepted: "USD",
  areaServed: SERVICE_AREAS.map((city) => ({
    "@type": "City",
    name: city,
    containedIn: { "@type": "State", name: "Wisconsin" }
  })),
  // Prices must stay in sync with the services list in src/pages/services.astro
  makesOffer: [
    {
      "@type": "Offer",
      price: "350",
      priceCurrency: "USD",
      itemOffered: {
        "@type": "MedicalProcedure",
        name: "Initial Consultation & Treatment",
        description: "Comprehensive health assessment, traditional Chinese medicine diagnosis, personalized treatment plan, and first acupuncture treatment"
      }
    },
    {
      "@type": "Offer",
      price: "90",
      priceCurrency: "USD",
      itemOffered: {
        "@type": "MedicalProcedure",
        name: "Acupuncture Treatment",
        description: "Traditional acupuncture for various conditions including chronic pain, stress, and wellness"
      }
    },
    {
      "@type": "Offer",
      price: "60",
      priceCurrency: "USD",
      itemOffered: {
        "@type": "MedicalProcedure",
        name: "Chinese Herbal Medicine Consultation",
        description: "Personalized Chinese herbal medicine consultation with custom formula recommendation"
      }
    },
    {
      "@type": "Offer",
      price: "45",
      priceCurrency: "USD",
      itemOffered: {
        "@type": "MedicalProcedure",
        name: "Cupping Therapy",
        description: "Traditional cupping therapy for pain relief and circulation"
      }
    }
  ],
  medicalSpecialty: [
    "Acupuncture",
    "Traditional Chinese Medicine",
    "Pain Management",
    "Integrative Medicine"
  ],
  founder: {
    "@type": "Person",
    name: "Dr. David Curry",
    jobTitle: "Licensed Acupuncturist",
    description: "Over 25 years of experience in acupuncture and traditional Chinese medicine"
  },
  knowsAbout: [
    "Acupuncture",
    "Holistic Acupuncture",
    "Traditional Chinese Medicine",
    "Chinese Herbal Medicine",
    "Cupping Therapy",
    "Chronic Pain Management",
    "Fertility Acupuncture",
    "Stress and Anxiety Relief"
  ],
  sameAs: [
    SOCIAL.facebook,
    SOCIAL.instagram,
    SOCIAL.linkedin,
    SOCIAL.twitterUrl,
    GOOGLE_BUSINESS_URL,
  ],
  hasCredential: {
    "@type": "EducationalOccupationalCredential",
    credentialCategory: "license",
    recognizedBy: {
      "@type": "Organization",
      name: "National Certification Commission for Acupuncture and Oriental Medicine (NCCAOM)"
    }
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
