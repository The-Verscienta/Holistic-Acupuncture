---
interface NavChild {
  name: string;
  href: string;
}
interface NavItem {
  name: string;
  href: string;
  children?: NavChild[];
}

const navigation: NavItem[] = [
  {
    name: 'About',
    href: '/about',
    children: [
      { name: 'About Us', href: '/about' },
      { name: 'About Acupuncture', href: '/acupuncture' },
      { name: 'Holistic Acupuncture', href: '/holistic-acupuncture' },
    ],
  },
  { name: 'Services', href: '/services' },
  { name: 'Conditions', href: '/conditions' },
  { name: 'Reviews', href: '/reviews' },
  { name: 'Blog', href: '/blog' },
  { name: 'FAQ', href: '/faq' },
];

// Match the active link by treating href as a path prefix so
// /blog/some-post still highlights "Blog" and /conditions/back-pain → "Conditions".
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
function isActive(href: string): boolean {
  return currentPath === href || currentPath.startsWith(href + '/');
}
// A dropdown parent is active when itself or any of its children match.
function isGroupActive(item: NavItem): boolean {
  return isActive(item.href) || (item.children ?? []).some((c) => isActive(c.href));
}
---

<nav class="flex items-center gap-1">
  {navigation.map((item) => {
    if (item.children && item.children.length > 0) {
      const active = isGroupActive(item);
      const menuId = `nav-${item.name.toLowerCase().replace(/\s+/g, '-')}-menu`;
      return (
        <div class="nav-dd relative group">
          <button
            type="button"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls={menuId}
            data-dropdown-trigger
            class:list={[
              'inline-flex items-center gap-1 px-2 xl:px-3 py-2 text-sm xl:text-base font-medium transition-colors relative',
              active ? 'text-sage-700' : 'text-gray-600 hover:text-sage-700',
            ]}
          >
            {item.name}
            <svg
              data-dropdown-chevron
              class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
            <span
              class:list={[
                'absolute bottom-0 left-2 xl:left-3 right-2 xl:right-3 h-0.5 bg-tcm-red transition-opacity duration-300',
                active ? 'opacity-100' : 'opacity-0',
              ]}
            ></span>
          </button>

          <div
            id={menuId}
            role="menu"
            data-dropdown-menu
            class="absolute left-0 top-full pt-3 z-50 min-w-[15rem] invisible opacity-0 translate-y-1 transition-all duration-150 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0"
          >
            <div class="bg-white rounded-[var(--radius-lg)] shadow-lg border border-sage-200 py-2">
              {item.children.map((child) => {
                const childActive = isActive(child.href);
                return (
                  <a
                    href={child.href}
                    role="menuitem"
                    aria-current={childActive ? 'page' : undefined}
                    class:list={[
                      'block px-4 py-2.5 text-sm xl:text-base transition-colors',
                      childActive
                        ? 'text-sage-700 bg-sage-50 font-semibold'
                        : 'text-gray-600 hover:text-sage-700 hover:bg-sage-50',
                    ]}
                  >
                    {child.name}
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      );
    }

    const active = isActive(item.href);
    return (
      <a
        href={item.href}
        aria-current={active ? 'page' : undefined}
        class:list={[
          'px-2 xl:px-3 py-2 text-sm xl:text-base font-medium transition-colors relative group',
          active ? 'text-sage-700' : 'text-gray-600 hover:text-sage-700',
        ]}
      >
        {item.name}
        <span
          class:list={[
            'absolute bottom-0 left-0 h-0.5 bg-tcm-red transition-all duration-300',
            active ? 'w-full' : 'w-0 group-hover:w-full',
          ]}
        ></span>
      </a>
    );
  })}
</nav>

<script>
  // Accessible dropdown: hover is handled by CSS (group-hover). This wires up
  // keyboard/click behaviour — toggle on click, sync aria-expanded, and close
  // on Escape, focus leaving the menu, or an outside click.
  function closeDropdown(dd: HTMLElement) {
    const trigger = dd.querySelector<HTMLButtonElement>('[data-dropdown-trigger]');
    const menu = dd.querySelector<HTMLElement>('[data-dropdown-menu]');
    const chevron = dd.querySelector<SVGElement>('[data-dropdown-chevron]');
    dd.classList.remove('nav-open');
    menu?.classList.add('invisible', 'opacity-0', 'translate-y-1');
    menu?.classList.remove('opacity-100', 'translate-y-0');
    chevron?.classList.remove('rotate-180');
    trigger?.setAttribute('aria-expanded', 'false');
  }

  function openDropdown(dd: HTMLElement) {
    const trigger = dd.querySelector<HTMLButtonElement>('[data-dropdown-trigger]');
    const menu = dd.querySelector<HTMLElement>('[data-dropdown-menu]');
    const chevron = dd.querySelector<SVGElement>('[data-dropdown-chevron]');
    dd.classList.add('nav-open');
    menu?.classList.remove('invisible', 'opacity-0', 'translate-y-1');
    menu?.classList.add('opacity-100', 'translate-y-0');
    chevron?.classList.add('rotate-180');
    trigger?.setAttribute('aria-expanded', 'true');
  }

  document.querySelectorAll<HTMLElement>('.nav-dd').forEach((dd) => {
    const trigger = dd.querySelector<HTMLButtonElement>('[data-dropdown-trigger]');
    if (!trigger) return;

    trigger.addEventListener('click', () => {
      if (dd.classList.contains('nav-open')) closeDropdown(dd);
      else openDropdown(dd);
    });

    dd.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeDropdown(dd);
        trigger.focus();
      }
    });

    // Close when focus moves outside the dropdown (keyboard tab-out).
    dd.addEventListener('focusout', (e) => {
      const next = e.relatedTarget as Node | null;
      if (!next || !dd.contains(next)) closeDropdown(dd);
    });
  });

  // Close any open (click-opened) dropdown when clicking elsewhere.
  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    document.querySelectorAll<HTMLElement>('.nav-dd.nav-open').forEach((dd) => {
      if (!dd.contains(target)) closeDropdown(dd);
    });
  });
</script>
