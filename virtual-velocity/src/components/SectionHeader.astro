---
interface Props {
  title: string;
  subtitle?: string;
  class?: string;
}

const { title, subtitle, class: className } = Astro.props;
---

<div class={`text-center mb-12 md:mb-16 ${className || ''}`}>
  <h2 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-charcoal mb-4 md:mb-6">
    {title}
  </h2>
  {subtitle && (
    <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto">
      {subtitle}
    </p>
  )}
</div>
