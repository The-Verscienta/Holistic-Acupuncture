---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StructuredData from '../components/StructuredData.astro';
import CookieConsent from '../components/CookieConsent.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { SITE_URL, SOCIAL, DEFAULT_OG_IMAGE, CONTACT, JANE_BOOKING_URL } from '../lib/config';

interface Props {
  title: string;
  description: string;
  image?: string;
  breadcrumbs?: { name: string; url?: string }[];
}

const { title, description, image, breadcrumbs } = Astro.props;
const siteOrigin = Astro.site?.origin || SITE_URL;
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const fullTitle = title === 'Home' ? 'Acupuncture & Holistic Health Associates | Milwaukee, WI' : `${title} | Acupuncture & Holistic Health Associates`;

// OG/Twitter require absolute image URLs; fall back to site logo if no page-specific image
const resolvedImage = image || DEFAULT_OG_IMAGE;
const imageUrl = resolvedImage.startsWith('http') ? resolvedImage : new URL(resolvedImage, siteOrigin).href;
const twitterHandle = SOCIAL.twitter;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
  <script is:inline>
    (function () {
      var now = new Date();
      var y = now.getFullYear(), m = now.getMonth() + 1, d = now.getDate();

      // Chinese New Year [month, day] by year — update table around 2040
      var cny = {
        2024:[2,10], 2025:[1,29], 2026:[2,17], 2027:[2,6],  2028:[1,26],
        2029:[2,13], 2030:[2,3],  2031:[1,23], 2032:[2,11], 2033:[1,31],
        2034:[2,19], 2035:[2,8],  2036:[1,28], 2037:[2,15], 2038:[2,4],
        2039:[1,24], 2040:[2,12]
      };

      // Emoji data stored in JS (not CSS) for reliable cross-browser access
      window.__holidayEmojis = {
        'christmas':        { logo: '🎄 ', deco: '🎄 ⛄ 🎁 ❄️' },
        'halloween':        { logo: '🎃 ', deco: '🎃 🕸️ 🦇' },
        'july-4th':         { logo: '🇺🇸 ', deco: '🎆 🇺🇸 🎇 ⭐' },
        'st-patricks':      { logo: '☘️ ',  deco: '☘️ 🍀 🌟 🎶' },
        'mlk':              { logo: '🕊️ ', deco: '✊ 🕊️ ⭐ 🌟' },
        'valentines':       { logo: '❤️ ',  deco: '💕 ❤️ 🌹 💝' },
        'chinese-new-year': { logo: '🧧 ', deco: '🧧 🐉 🏮 🎆' },
        'veterans':         { logo: '🎖️ ', deco: '🇺🇸 ⭐ 🎖️ 🦅' }
      };

      // Returns day-of-month of the Nth Monday in a given month.
      // Formula: 1 + ((8 - dow) % 7) gives the day of the first Monday.
      // Verified: Jan 2026 starts Thu (dow=4) → firstMonday=5 → 3rd=19 ✓
      function nthMonday(year, month, n) {
        var date = new Date(year, month - 1, 1);
        var dow = date.getDay();
        var firstMonday = 1 + ((8 - dow) % 7);
        return firstMonday + (n - 1) * 7;
      }

      // DST-safe date window check using YYYYMMDD integer comparison.
      // NOTE: not safe across year boundaries — Christmas uses an explicit
      // range instead (see detect() below).
      function inWindow(y, m, d, wy, wm, wd, days) {
        function toInt(yy, mm, dd) { return yy * 10000 + mm * 100 + dd; }
        var target = new Date(wy, wm - 1, wd);
        var lo = new Date(target); lo.setDate(target.getDate() - days);
        var hi = new Date(target); hi.setDate(target.getDate() + days);
        var check = toInt(y, m, d);
        return check >= toInt(lo.getFullYear(), lo.getMonth() + 1, lo.getDate())
            && check <= toInt(hi.getFullYear(), hi.getMonth() + 1, hi.getDate());
      }

      function detect(y, m, d) {
        // Christmas window: Dec 11 – Jan 1 (intentionally asymmetric: 14 days
        // before Dec 25, 7 days after). Uses explicit range instead of inWindow()
        // because the window crosses a year boundary.
        if ((m === 12 && d >= 11) || (m === 1 && d === 1)) return 'christmas';

        var mlk  = nthMonday(y, 1, 3);
        var cnyd = cny[y];

        // Priority order (highest first after Christmas):
        if (inWindow(y, m, d, y, 10, 31, 4))                      return 'halloween';
        if (cnyd && inWindow(y, m, d, y, cnyd[0], cnyd[1], 3))    return 'chinese-new-year';
        if (inWindow(y, m, d, y, 2,  14, 7))                      return 'valentines';
        if (inWindow(y, m, d, y, 3,  17, 7))                      return 'st-patricks';
        if (inWindow(y, m, d, y, 7,  4,  7))                      return 'july-4th';
        if (inWindow(y, m, d, y, 1,  mlk, 3))                     return 'mlk';
        if (inWindow(y, m, d, y, 11, 11, 7))                      return 'veterans';
        return null;
      }

      var holiday = detect(y, m, d);
      if (holiday) document.documentElement.dataset.holiday = holiday;

      // Emoji injection runs after the DOM is ready (logo + deco elements exist).
      document.addEventListener('DOMContentLoaded', function () {
        var h = document.documentElement.dataset.holiday;
        if (!h || !window.__holidayEmojis[h]) return;
        var data = window.__holidayEmojis[h];
        var deco   = document.getElementById('holiday-deco');
        var lel    = document.getElementById('holiday-emoji');
        var footer = document.getElementById('holiday-footer-emoji');
        if (deco)   deco.textContent   = data.deco;
        if (lel)    lel.textContent    = data.logo;
        if (footer) footer.textContent = data.logo;
        document.querySelectorAll('.holiday-btn-emoji').forEach(function (el) {
          el.textContent = data.logo;
        });
      });
    })();
  </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="acupuncture, holistic health, traditional Chinese medicine, Milwaukee, Wisconsin, pain management, stress relief, fertility support, natural healing" />
    <meta name="author" content="Acupuncture & Holistic Health Associates" />

    <!-- SEO -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content={image ? "630" : "896"} />
    <meta property="og:site_name" content="Acupuncture & Holistic Health Associates" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    {twitterHandle && <meta name="twitter:site" content={twitterHandle} />}
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <!-- Local Business Info -->
    <meta name="geo.region" content="US-WI" />
    <meta name="geo.placename" content="Glendale" />
    <meta name="geo.position" content="43.145805;-87.888920" />
    <meta name="ICBM" content="43.145805, -87.888920" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#657a52" />

    <!-- Fonts loaded via Google Fonts (rewritten by Cloudflare Fonts at the edge) -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=Inter:wght@400;600&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&display=swap"
    />

    <!-- Structured Data -->
    <StructuredData />
    {breadcrumbs && breadcrumbs.length > 1 && <Breadcrumb items={breadcrumbs} />}

    <!-- Google Analytics 4 is loaded via CookieConsent component after user accepts -->

    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Skip Navigation Link for Accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-sage-700 focus:text-white focus:rounded-md focus:shadow-lg"
    >
      Skip to main content
    </a>

    <Header />
    <main id="main-content" class="flex-1" data-pagefind-body>
      <slot />
    </main>
    <Footer />
    <CookieConsent />

    <!-- Mobile sticky Book Now bar (hidden on lg+ where header button is visible) -->
    <div
      id="mobile-book-bar"
      class="fixed bottom-0 left-0 right-0 z-40 lg:hidden bg-white border-t border-gray-200 shadow-lg px-4 py-3 flex items-center gap-3 translate-y-full transition-transform duration-300"
      aria-hidden="true"
    >
      <a
        href={`tel:${CONTACT.phoneRaw}`}
        class="flex-1 flex items-center justify-center gap-2 py-3 rounded-lg border border-sage-300 text-sage-700 font-semibold text-sm"
        aria-label={`Call ${CONTACT.phone}`}
      >
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        Call Us
      </a>
      <a
        href={JANE_BOOKING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-[2] flex items-center justify-center gap-2 py-3 rounded-lg bg-sage-700 hover:bg-sage-600 text-white font-semibold text-sm transition-colors"
      >
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        Book Appointment
      </a>
    </div>

    <script is:inline>
      (function () {
        var bar = document.getElementById('mobile-book-bar');
        if (!bar) return;
        var shown = false;
        window.addEventListener('scroll', function () {
          if (window.scrollY > 300 && !shown) {
            shown = true;
            bar.classList.remove('translate-y-full');
            bar.removeAttribute('aria-hidden');
          }
        }, { passive: true });
      })();
    </script>

  <script is:inline>
    (function () {
      var h = document.documentElement.dataset.holiday;
      if (!h) return;
      if (sessionStorage.getItem('holiday-confetti-shown')) return;
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      sessionStorage.setItem('holiday-confetti-shown', '1');

      function runEffect() {
        var c = window.confetti;

        if (h === 'christmas') {
          // Gentle falling snow for 10 seconds
          var end = Date.now() + 10000;
          (function snow() {
            c({ particleCount: 3, angle: 90, spread: 140,
                origin: { x: Math.random(), y: -0.05 },
                colors: ['#ffffff', '#cce8ff', '#e0f0ff'],
                shapes: ['circle'], gravity: 0.25, scalar: 0.7,
                drift: (Math.random() - 0.5) * 0.6, ticks: 500 });
            if (Date.now() < end) requestAnimationFrame(snow);
          })();

        } else if (h === 'halloween') {
          c({ particleCount: 100, spread: 120, origin: { y: 0.65 },
              colors: ['#ff6b00', '#ff9500', '#2d1b4e', '#9c27b0', '#ffffff'],
              shapes: ['circle', 'square'], scalar: 1.2, gravity: 1.2 });

        } else if (h === 'july-4th') {
          // Three staggered firework bursts
          var bursts = 3;
          function burst() {
            c({ particleCount: 60, startVelocity: 35, spread: 360,
                origin: { x: 0.2 + Math.random() * 0.6, y: 0.2 + Math.random() * 0.3 },
                colors: ['#001f5b', '#ffffff', '#8b0000', '#cc0000'],
                shapes: ['circle'], ticks: 80, gravity: 0.8 });
            if (--bursts > 0) setTimeout(burst, 350);
          }
          burst();

        } else if (h === 'st-patricks') {
          c({ particleCount: 100, spread: 130, origin: { y: 0.65 },
              colors: ['#2a5c1a', '#1a4a1a', '#f5e642', '#ffffff', '#4caf50'],
              shapes: ['circle', 'square'], scalar: 1 });

        } else if (h === 'valentines') {
          c({ particleCount: 90, spread: 130, origin: { y: 0.65 },
              colors: ['#e91e63', '#ff4081', '#ffb3c6', '#ffffff', '#ff6b9d'],
              shapes: ['circle'], scalar: 1.1 });

        } else if (h === 'chinese-new-year') {
          c({ particleCount: 120, spread: 140, origin: { y: 0.65 },
              colors: ['#ffd700', '#ff0000', '#8b0000', '#ffb300', '#ffffff'],
              shapes: ['circle', 'square'], scalar: 1.2, gravity: 1.2 });

        } else if (h === 'mlk') {
          c({ particleCount: 70, spread: 110, origin: { y: 0.65 },
              colors: ['#d4af37', '#ffffff', '#c8a83c', '#f5e642'],
              shapes: ['circle'], scalar: 1 });

        } else if (h === 'veterans') {
          c({ particleCount: 80, spread: 110, origin: { y: 0.65 },
              colors: ['#ffffff', '#c8a83c', '#0a1628', '#1a3050'],
              shapes: ['circle', 'square'], scalar: 1 });
        }
      }

      // Dynamically load canvas-confetti only during a holiday week
      var s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js';
      s.onload = runEffect;
      document.body.appendChild(s);
    })();
  </script>
  </body>
</html>
