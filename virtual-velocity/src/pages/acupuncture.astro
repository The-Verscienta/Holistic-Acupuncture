---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';
import { CONTACT } from '../lib/config';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTASection from '../components/CTASection.astro';
import FeatureCard from '../components/FeatureCard.astro';
import StepCard from '../components/StepCard.astro';
import NewPatientSpecial from '../components/NewPatientSpecial.astro';
---

<BaseLayout
  title="Acupuncture in Milwaukee, WI"
  description="Acupuncture in Milwaukee & Glendale, WI. Licensed acupuncturists with 25+ years' experience treating pain, stress, fertility & more. Book your first visit today."
  breadcrumbs={[{name:'Home',url:'/'},{name:'Acupuncture in Milwaukee'}]}
>
  <!-- Hero Section -->
  <PageHero
    title="Acupuncture in Milwaukee, WI"
    description="Trusted acupuncture and traditional Chinese medicine for Milwaukee and Glendale residents — natural, lasting relief from pain, stress, and chronic conditions."
  />

  <!-- What is Acupuncture -->
  <section class="py-16 md:py-20 lg:py-24 bg-white">
    <Container>
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-charcoal mb-6">
            What is Acupuncture?
          </h2>
          <div class="space-y-4 text-gray-700 leading-relaxed">
            <p>
              Acupuncture is a holistic healing practice that has been refined over 3,000 years of clinical use in China and Asia. It involves the insertion of ultra-fine, sterile needles into specific points on the body to stimulate healing and restore balance.
            </p>
            <p>
              According to traditional Chinese medicine theory, acupuncture works by regulating the flow of Qi (pronounced "chee") - the vital energy that flows through pathways called meridians in your body. When Qi flows freely, you experience good health. When it's blocked or imbalanced, illness and pain can result.
            </p>
            <p>
              Modern research has shown that acupuncture points correspond to areas of high electrical conductivity and increased concentrations of nerve endings. Stimulating these points triggers the release of endorphins, reduces inflammation, and activates the body's natural healing mechanisms.
            </p>
          </div>
        </div>

        <div class="space-y-6">
          <Card variant="elevated" padding="lg" class="bg-gradient-to-br from-sage-50 to-warm-white">
            <h3 class="text-xl font-heading font-semibold text-charcoal mb-4">
              Scientific Evidence
            </h3>
            <ul class="space-y-3 text-gray-700 text-sm">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-sage-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Endorsed by the World Health Organization (WHO) for over 100 conditions</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-sage-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Recognized by the National Institutes of Health (NIH) for pain management</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-sage-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Backed by thousands of peer-reviewed research studies</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-sage-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Covered by many insurance plans for specific conditions</span>
              </li>
            </ul>
          </Card>
        </div>
      </div>
    </Container>
  </section>

  <!-- Why Milwaukee Residents Choose Acupuncture -->
  <section class="py-16 md:py-20 lg:py-24 bg-sage-50">
    <Container>
      <div class="max-w-4xl mx-auto">
        <SectionHeader title="Why Milwaukee Residents Choose Acupuncture" subtitle="Natural, drug-free care suited to life in southeastern Wisconsin" />

        <div class="space-y-4 text-gray-700 leading-relaxed">
          <p>
            Life in Milwaukee comes with its own set of physical demands. Long, cold winters keep many of us indoors and less active, while icy sidewalks, snow shoveling, and months of sitting can stiffen joints and aggravate chronic back, neck, and shoulder pain. When spring finally arrives, the same lakeside climate that we love brings a heavy season of pollen and seasonal allergies. Add the everyday stress of work, commuting, and family life, and it is easy to see why so many people are looking for relief that does not rely on another prescription.
          </p>
          <p>
            That is exactly where acupuncture in Milwaukee can help. More and more local patients are turning to drug-free, non-surgical care to manage pain, calm anxiety and stress, sleep better, and support their overall wellbeing. Rather than masking symptoms, acupuncture works with your body's own healing systems — which is why it appeals to people who want a gentler first step before, or alongside, conventional treatment.
          </p>
          <p>
            There is also a growing awareness across Wisconsin of the downsides of relying on pain medication for the long term. Many of our patients are actively looking for ways to reduce how often they reach for over-the-counter or prescription drugs, and they appreciate that acupuncture carries very few side effects when it is performed by a licensed practitioner. For others, the appeal is simply how restorative the treatments feel: a quiet hour to step away from screens, traffic, and a packed calendar, and to give the nervous system a chance to truly settle. Both outcomes — fewer medications and deeper rest — point to the same thing, which is care that treats you as a whole person rather than a list of symptoms.
          </p>
          <p>
            As an established Milwaukee acupuncture clinic, we are proud to care for patients from across the metro area and the North Shore. Our practice welcomes residents from Milwaukee, Glendale, Shorewood, Whitefish Bay, Mequon, Bayside, Fox Point, and Wauwatosa, many of whom are just a short drive away. Whether you are coping with a stubborn old injury or simply want to feel more like yourself again, our licensed acupuncturists tailor every treatment plan to your body, your history, and your goals.
          </p>
          <p>
            What sets acupuncture apart for many Milwaukee patients is that it is a partnership rather than a one-time fix. We take time to understand how your symptoms fit into the bigger picture of your daily routine, your work, and the seasons that shape life here in Wisconsin. That perspective allows us to recommend small, practical changes alongside your treatments, so the benefits you feel on the table carry over into the rest of your week. For people who have spent years moving from one provider to the next without lasting answers, this kind of patient, individualized attention can make all the difference.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- How Acupuncture Works -->
  <section class="py-16 md:py-20 lg:py-24 bg-white">
    <Container>
      <SectionHeader title="How Acupuncture Works" subtitle="Understanding the mechanisms behind this powerful healing modality" />

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        <FeatureCard title="Stimulates Nerves" description="Needles activate nerve endings, sending healing signals to the brain and affected areas" icon="M13 10V3L4 14h7v7l9-11h-7z" layout="centered" cardVariant="elevated" />
        <FeatureCard title="Releases Endorphins" description="Natural pain-relieving chemicals flood your system, providing relief and promoting wellbeing" icon="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" layout="centered" cardVariant="elevated" />
        <FeatureCard title="Reduces Inflammation" description="Anti-inflammatory chemicals are released, reducing swelling and promoting tissue healing" icon="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" layout="centered" cardVariant="elevated" />
        <FeatureCard title="Boosts Immunity" description="White blood cell production increases, strengthening your body's natural defenses" icon="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" layout="centered" cardVariant="elevated" />
      </div>
    </Container>
  </section>

  <!-- What to Expect -->
  <section class="py-16 md:py-20 lg:py-24 bg-sage-50">
    <Container>
      <div class="max-w-4xl mx-auto">
        <SectionHeader title="What to Expect During Your Visit" subtitle="Your first acupuncture experience, step by step" />

        <div class="space-y-6">
          <StepCard number={1} title="Initial Consultation (30-45 minutes)">
            <p class="text-gray-700 leading-relaxed mb-3">
              We begin with a comprehensive health history and discussion of your main concerns. We'll ask about your symptoms, medical history, lifestyle, diet, and sleep patterns.
            </p>
            <p class="text-gray-700 leading-relaxed">
              In traditional Chinese medicine, we also examine your tongue and take your pulse at multiple points, which provides valuable diagnostic information.
            </p>
          </StepCard>

          <StepCard number={2} title="Treatment Plan">
            <p class="text-gray-700 leading-relaxed">
              Based on your consultation, we'll create a personalized treatment plan tailored to your specific needs and health goals. We'll explain which acupuncture points we'll use and what you can expect from treatment.
            </p>
          </StepCard>

          <StepCard number={3} title="Acupuncture Treatment (30-45 minutes)">
            <p class="text-gray-700 leading-relaxed mb-3">
              You'll lie comfortably on a treatment table while we insert ultra-fine needles (thinner than a human hair) at specific points. Most people feel minimal to no discomfort.
            </p>
            <p class="text-gray-700 leading-relaxed">
              The needles remain in place for 20-30 minutes while you relax. Many patients find this time deeply relaxing and even fall asleep.
            </p>
          </StepCard>

          <StepCard number={4} title="Post-Treatment & Follow-Up">
            <p class="text-gray-700 leading-relaxed">
              After removing the needles, we'll discuss your experience and provide recommendations for home care, diet, or lifestyle modifications that can enhance your results. We'll also schedule your follow-up appointments based on your treatment plan.
            </p>
          </StepCard>
        </div>
      </div>
    </Container>
  </section>

  <!-- Our Glendale Acupuncture Clinic -->
  <section class="py-16 md:py-20 lg:py-24 bg-white">
    <Container>
      <div class="max-w-4xl mx-auto">
        <SectionHeader title="Our Glendale Acupuncture Clinic" subtitle="A calm, convenient setting for the Milwaukee area and North Shore" />

        <div class="space-y-4 text-gray-700 leading-relaxed">
          <p>
            Our clinic is located in Glendale, WI, just minutes from Milwaukee's north side and the surrounding North Shore suburbs. The location makes it easy to fit a treatment into a busy day, whether you are coming from home, work, or an errand nearby. Free, on-site parking means you can arrive without circling the block or feeding a meter, and our entrance is simple to find on your first visit.
          </p>
          <p>
            Inside, you will find quiet, comfortable treatment rooms designed to help you unwind from the moment you sit down. Many patients tell us the experience feels less like a typical medical appointment and more like a genuine chance to rest and reset. To make care accessible around your schedule, we offer flexible daytime and evening appointments throughout the week.
          </p>
          <p>
            We also know that cost and insurance are important parts of your decision. Our practice is in-network with many major insurance providers, and acupuncture is increasingly covered for conditions such as chronic pain. We are happy to help you verify your coverage before you begin, and you can always <a href="/services" class="text-sage-600 hover:text-sage-700 underline">see our transparent pricing</a> or <a href="/contact" class="text-sage-600 hover:text-sage-700 underline">reach out with any questions</a> about your first appointment.
          </p>
          <p>
            If you have never tried acupuncture before, it is completely normal to feel a little unsure about that first appointment. We take time to answer your questions, explain each step, and make sure you feel comfortable before any treatment begins. There is no need to prepare anything special beforehand — simply wear loose, comfortable clothing, eat a light meal so you are not arriving hungry, and give yourself a few unhurried minutes to settle in once you arrive in Glendale. From your first phone call to your follow-up visits, our goal is to make care feel approachable, unrushed, and genuinely supportive.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Conditions We Treat with Acupuncture -->
  <section class="py-16 md:py-20 lg:py-24 bg-sage-50">
    <Container>
      <div class="max-w-4xl mx-auto">
        <SectionHeader title="Conditions We Treat with Acupuncture" subtitle="Whole-person care for a wide range of health concerns" />

        <div class="space-y-4 text-gray-700 leading-relaxed">
          <p>
            Acupuncture supports far more than back pain. Our Milwaukee-area patients come to us for help with chronic and acute pain, headaches and migraines, stress and anxiety, digestive issues, sleep problems, women's health and fertility, seasonal allergies, and many other conditions. Because traditional Chinese medicine looks at the whole person rather than a single symptom, we often address the root causes that keep a problem coming back.
          </p>
          <p>
            That whole-person view is especially valuable when several issues overlap, which is often the case in real life. Poor sleep can worsen pain, ongoing stress can upset digestion, and chronic discomfort can wear down your mood and energy over time. Instead of treating each of these in isolation, we look for the connections between them and design a plan that helps your body find better balance overall. Many patients are surprised to notice improvements in areas they did not even come in for — sleeping more soundly, feeling calmer, or simply having more energy to enjoy life around Milwaukee and the North Shore.
          </p>
          <p>
            Every body responds differently, so we build a personalized plan around your specific concerns and goals. Some patients come in for a single nagging issue, while others use regular sessions as a way to manage stress, support their immune system, and stay ahead of the aches that can build up over a long Milwaukee winter. To see whether acupuncture may be a good fit for what you are experiencing, <a href="/conditions" class="text-sage-600 hover:text-sage-700 underline">explore all the conditions we treat</a>.
          </p>
          <p class="text-gray-700 leading-relaxed mt-4">
            Interested in a whole-person approach? Learn about our
            <a href="/holistic-acupuncture" class="text-sage-600 hover:text-sage-700 underline">holistic acupuncture and Chinese medicine in Milwaukee</a>.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 md:py-20 lg:py-24 bg-white">
    <Container>
      <div class="max-w-3xl mx-auto">
        <SectionHeader title="Common Questions" subtitle="Answers to the most frequently asked questions about acupuncture" />

        <div class="space-y-4">
          <Card variant="elevated" padding="lg">
            <h3 class="text-lg font-heading font-semibold text-charcoal mb-3">
              Does acupuncture hurt?
            </h3>
            <p class="text-gray-700 leading-relaxed">
              Most people feel little to no pain. The needles are extremely thin - much finer than needles used for injections. You may feel a slight pinch upon insertion, followed by a sensation of warmth, tingling, or heaviness, which indicates the treatment is working.
            </p>
          </Card>

          <Card variant="elevated" padding="lg">
            <h3 class="text-lg font-heading font-semibold text-charcoal mb-3">
              How many treatments will I need?
            </h3>
            <p class="text-gray-700 leading-relaxed">
              This varies depending on your condition and how long you've had it. Acute conditions may resolve in 3-6 sessions, while chronic issues typically require 8-12 sessions for significant improvement. We'll discuss a treatment plan during your first visit.
            </p>
          </Card>

          <Card variant="elevated" padding="lg">
            <h3 class="text-lg font-heading font-semibold text-charcoal mb-3">
              Is acupuncture safe?
            </h3>
            <p class="text-gray-700 leading-relaxed">
              Yes, when performed by a licensed practitioner. We use single-use, sterile needles and follow strict safety protocols. Side effects are rare and typically limited to minor bruising or temporary soreness at needle sites.
            </p>
          </Card>

          <Card variant="elevated" padding="lg">
            <h3 class="text-lg font-heading font-semibold text-charcoal mb-3">
              Will my insurance cover acupuncture?
            </h3>
            <p class="text-gray-700 leading-relaxed">
              Many insurance plans now cover acupuncture for specific conditions like chronic pain. We recommend calling your insurance provider to verify your coverage. We can provide documentation you may need for reimbursement.
            </p>
          </Card>

          <div class="text-center pt-8">
            <Button variant="tertiary" size="lg" href="/contact">
              Have More Questions? Contact Us
            </Button>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <NewPatientSpecial />

  <!-- CTA Section -->
  <CTASection
    heading="Experience the Benefits of Acupuncture"
    description="Join thousands of patients who have found natural relief and lasting wellness through our expert acupuncture care."
    primaryButton={{ label: 'Book Your First Visit', href: '/contact' }}
    secondaryButton={{ label: `Call ${CONTACT.phone}`, href: `tel:+1${CONTACT.phone.replace(/\D/g, '')}`, icon: 'phone' }}
  />
</BaseLayout>
