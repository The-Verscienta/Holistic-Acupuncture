---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import Card from '../../components/Card.astro';
import Button from '../../components/Button.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import CTASection from '../../components/CTASection.astro';
import NewPatientSpecial from '../../components/NewPatientSpecial.astro';
import { LOCATIONS } from '../../data/locations';
import { CONTACT, HOURS, BOOK_PATH } from '../../lib/config';

export function getStaticPaths() {
  return LOCATIONS.map((loc) => ({ params: { location: loc.slug }, props: { loc } }));
}

const { loc } = Astro.props;
const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination_place_id=${CONTACT.address.googlePlaceId}`;
---

<BaseLayout
  title={loc.metaTitle}
  description={loc.metaDescription}
  breadcrumbs={[{name:'Home',url:'/'},{name:'Acupuncture',url:'/acupuncture'},{name:loc.name}]}
>
  <section class="bg-gradient-to-br from-sage-50 to-warm-white py-12 md:py-16">
    <Container>
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-charcoal mb-4">Acupuncture in {loc.name}, WI</h1>
      <p class="text-lg text-gray-600 max-w-2xl">{loc.intro}</p>
    </Container>
  </section>

  <!-- Local Intro -->
  <section class="py-12 md:py-16 bg-white">
    <Container>
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          title={`Acupuncture Care for ${loc.name} Residents`}
          subtitle="Whole-person care from your neighbors in Glendale"
        />

        <div class="space-y-4 text-gray-700 leading-relaxed">
          {loc.localParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          <p>
            Curious whether acupuncture can help with your specific concern? Explore the full list of
            <a href="/conditions" class="text-sage-600 hover:text-sage-700 underline">conditions we treat</a>,
            see our
            <a href="/services" class="text-sage-600 hover:text-sage-700 underline">services and transparent pricing</a>,
            or learn about our
            <a href="/holistic-acupuncture" class="text-sage-600 hover:text-sage-700 underline">holistic, whole-person approach</a>.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Getting Here -->
  <section class="py-12 md:py-16 bg-sage-50">
    <Container>
      <div class="max-w-5xl mx-auto">
        <SectionHeader
          title={`Getting Here from ${loc.name}`}
          subtitle={loc.driveTime}
        />

        <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-start">
          <div class="space-y-4 text-gray-700 leading-relaxed">
            {loc.directionsParagraphs.map((paragraph) => <p>{paragraph}</p>)}
            <p>
              Your first visit includes a thorough consultation and your first treatment. We use ultra-fine,
              single-use sterile needles, and most patients find sessions deeply relaxing. New to acupuncture?
              Start with our overview of
              <a href="/acupuncture" class="text-sage-600 hover:text-sage-700 underline">acupuncture in Milwaukee</a>.
            </p>
          </div>

          <Card variant="elevated" padding="lg">
            <h3 class="text-xl font-heading font-semibold text-charcoal mb-4">
              Acupuncture &amp; Holistic Health Associates
            </h3>
            <ul class="space-y-3 text-gray-700 text-sm mb-6">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-sage-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <span>{CONTACT.address.street}<br>{CONTACT.address.city}, {CONTACT.address.state} {CONTACT.address.zip}</span>
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-sage-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
                <a href={`tel:${CONTACT.phoneRaw}`} class="hover:text-sage-700 transition-colors">{CONTACT.phone}</a>
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-sage-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>Mon–Thu: {HOURS.monday}</span>
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-sage-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Free on-site parking</span>
              </li>
            </ul>
            <Button
              variant="secondary"
              size="md"
              href={directionsUrl}
              class="w-full justify-center"
            >
              Get Directions
            </Button>
          </Card>
        </div>
      </div>
    </Container>
  </section>

  <NewPatientSpecial />

  <CTASection
    heading={`Ready to try acupuncture in ${loc.name}?`}
    description="Book your first visit today — a short drive could be the start of lasting relief."
    primaryButton={{ label: 'Book Appointment', href: BOOK_PATH }}
    secondaryButton={{ label: `Call ${CONTACT.phone}`, href: `tel:${CONTACT.phoneRaw}`, icon: 'phone' }}
  />
</BaseLayout>
